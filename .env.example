# Copy this file to .env and fill in values for your local setup.
# Do not commit the real .env file: it may contain private tokens.

# Ollama chat API endpoint.
# Local Ollama default:
OLLAMA_URL=http://localhost:11434/api/chat

# Model name installed in Ollama.
# Check available models with: ollama list
OLLAMA_MODEL=llama3.2

# Optional API key for a proxy or a secured Ollama-compatible endpoint.
# Leave empty for a regular local Ollama installation.
OLLAMA_API_KEY=
